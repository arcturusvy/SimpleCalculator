<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.SimpleCalculator" parent="Theme.Material3.DayNight.NoActionBar">
    </style>

    <style name="Theme.SimpleCalculator" parent="Base.Theme.SimpleCalculator" />


    <style name="AdvancedCalcButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="cornerRadius">100dp</item>
        <item name="backgroundTint">#212121</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="NumberButton" parent="AdvancedCalcButton">
        <item name="android:textSize">26sp</item>
        <item name="android:layout_margin">4dp</item>
    </style>

    <style name="TopStandardButton" parent="NumberButton">
        <item name="backgroundTint">#A5A5A5</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="OperatorButton" parent="NumberButton">
        <item name="backgroundTint">#FF9F0A</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">32sp</item>
    </style>

</resources>