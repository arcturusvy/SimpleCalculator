<resources xmlns:tools="http://schemas.android.com/tools" xmlns:app="http://schemas.android.com/apk/res-auto">
    <style name="Base.Theme.SimpleCalculator" parent="Theme.Material3.DayNight.NoActionBar">
    </style>

    <style name="Theme.SimpleCalculator" parent="Base.Theme.SimpleCalculator" />

    <style name="CalcButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:backgroundTint">#333333</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="ScientificButton" parent="CalcButton">
        <item name="android:backgroundTint">#2E2E2E</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="CalcButtonGray" parent="CalcButton">
        <item name="android:backgroundTint">#A5A5A5</item>
        <item name="android:textColor">#000000</item>
    </style>

    <style name="CalcButtonOrange" parent="CalcButton">
        <item name="android:backgroundTint">#FF9F0A</item>
        <item name="android:textSize">28sp</item>
    </style>

</resources>